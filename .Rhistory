knitr::opts_chunk$set(echo = TRUE)
library(readr)
url <- "https://fred.stlouisfed.org/graph/fredgraph.csv?id=UNRATE"
unrate_data <- read_csv(url)
stl(unrate_data)
library(readr)
url <- "https://fred.stlouisfed.org/graph/fredgraph.csv?id=UNRATE"
unrate_data <- read_csv(url)
ts(unrate_data)
stl(unrate_data)
library(readr)
url <- "https://fred.stlouisfed.org/graph/fredgraph.csv?id=UNRATE"
unrate_data <- read_csv(url)
ts(unrate_data)
decompose(unrate_data)
View(unrate_data)
#read the data from the fed website
library(readr)
url <- "https://fred.stlouisfed.org/graph/fredgraph.csv?id=UNRATE"
unrate_data <- read_csv(url)
#convert to time series
unrate_ts <- ts(unrate_data$UNRATE, start = c(1984, 1), frequency = 12)
#decompose and plot
unrate_decomp <- decompose(unrate_ts)
View(unrate_data)
#read the data from the fed website
library(readr)
url <- "https://fred.stlouisfed.org/graph/fredgraph.csv?id=UNRATE"
unrate_data <- read_csv(url)
#convert to time series
unrate_ts <- ts(unrate_data$UNRATE, start = c(1984, 1), frequency = 12)
#interpolate the NA values
library(forecast)
unrate_ts_interp <- na.interp(unrate_ts)
#decompose and plot
unrate_decomp <- decompose(unrate_ts_interp)
plot(unrate_decomp)
